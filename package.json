    "dompurify": "3.3.3",
    "lucide-react": "1.7.0",
    "marked": "17.0.5",
    "motion": "12.38.0",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2"
