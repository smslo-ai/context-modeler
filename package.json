    "validate": "npm run typecheck && npm run lint && npm run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
